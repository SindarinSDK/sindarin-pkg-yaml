// Tests for Yaml encoder/decoder with @serializable structs
import "../src/yaml"

@serializable
struct Address =>
  street: str
  city: str

@serializable
struct Person =>
  name: str
  age: int
  score: double
  active: bool
  address: Address
  tags: str[]

@serializable
struct Team =>
  name: str
  members: Person[]

@serializable
struct EdgeRule =>
  @alias "type"
  kind: str
  @alias "max_gap_ms"
  maxGapMs: int
  threshold: double

@serializable
struct RuleConfig =>
  name: str
  @alias "edge_rules"
  edgeRules: EdgeRule[]

fn main(): void =>
  // --- Test 1: Simple struct encode ---
  var a: Address = {
    street: "123 Main St",
    city: "NYC"
  }
  var yaml: str = a.encode(Yaml.encoder())
  assert(yaml == "street: \"123 Main St\"\ncity: \"NYC\"", "Address encode")
  println("test_encode_address: PASS")

  // --- Test 2: Complex struct encode ---
  var p: Person = {
    name: "Alice",
    age: 30,
    score: 9.5,
    active: true,
    address: Address {
      street: "456 Oak Ave",
      city: "LA"
    },
    tags: {"dev", "lead"}
  }
  var yaml2: str = p.encode(Yaml.encoder())
  assert(yaml2 == "name: \"Alice\"\nage: 30\nscore: 9.5\nactive: true\naddress:\n  street: \"456 Oak Ave\"\n  city: \"LA\"\ntags:\n  - \"dev\"\n  - \"lead\"", "Person encode")
  println("test_encode_person: PASS")

  // --- Test 3: Simple struct decode ---
  var dec: Decoder = Yaml.decoder("street: \"789 Pine Rd\"\ncity: \"Chicago\"")
  var a2: Address = Address.decode(dec)
  assert(a2.street == "789 Pine Rd", "Address decode street")
  assert(a2.city == "Chicago", "Address decode city")
  println("test_decode_address: PASS")

  // --- Test 4: Complex struct decode ---
  var dec2: Decoder = Yaml.decoder("name: \"Bob\"\nage: 25\nscore: 8.3\nactive: false\naddress:\n  street: \"10 Elm\"\n  city: \"SF\"\ntags:\n  - \"ops\"\n  - \"sre\"")
  var p2: Person = Person.decode(dec2)
  assert(p2.name == "Bob", "Person decode name")
  assert(p2.age == 25, "Person decode age")
  assert(p2.score == 8.3, "Person decode score")
  assert(p2.active == false, "Person decode active")
  assert(p2.address.street == "10 Elm", "Person decode address.street")
  assert(p2.address.city == "SF", "Person decode address.city")
  assert(p2.tags.length == 2, "Person decode tags length")
  assert(p2.tags[0] == "ops", "Person decode tags[0]")
  assert(p2.tags[1] == "sre", "Person decode tags[1]")
  println("test_decode_person: PASS")

  // --- Test 5: Roundtrip ---
  var original: Person = {
    name: "Charlie",
    age: 40,
    score: 7.7,
    active: true,
    address: Address {
      street: "99 River Dr",
      city: "Boston"
    },
    tags: {"mgr"}
  }
  var rtYaml: str = original.encode(Yaml.encoder())
  var roundtrip: Person = Person.decode(Yaml.decoder(rtYaml))
  assert(roundtrip.name == "Charlie", "roundtrip name")
  assert(roundtrip.age == 40, "roundtrip age")
  assert(roundtrip.score == 7.7, "roundtrip score")
  assert(roundtrip.active == true, "roundtrip active")
  assert(roundtrip.address.street == "99 River Dr", "roundtrip address.street")
  assert(roundtrip.address.city == "Boston", "roundtrip address.city")
  assert(roundtrip.tags.length == 1, "roundtrip tags length")
  assert(roundtrip.tags[0] == "mgr", "roundtrip tags[0]")
  println("test_roundtrip: PASS")

  // --- Test 6: Array of structs ---
  var team: Team = {
    name: "Engineering",
    members: {
      Person {
        name: "Alice",
        age: 30,
        score: 9.0,
        active: true,
        address: Address {
          street: "1 A",
          city: "X"
        },
        tags: {"a"}
      },
      Person {
        name: "Bob",
        age: 25,
        score: 8.0,
        active: false,
        address: Address {
          street: "2 B",
          city: "Y"
        },
        tags: {"b", "c"}
      }
    }
  }
  var tYaml: str = team.encode(Yaml.encoder())
  var team2: Team = Team.decode(Yaml.decoder(tYaml))
  assert(team2.name == "Engineering", "team name")
  assert(team2.members.length == 2, "team members count")
  assert(team2.members[0].name == "Alice", "team member 0 name")
  assert(team2.members[0].age == 30, "team member 0 age")
  assert(team2.members[0].address.city == "X", "team member 0 city")
  assert(team2.members[1].name == "Bob", "team member 1 name")
  assert(team2.members[1].tags.length == 2, "team member 1 tags count")
  assert(team2.members[1].tags[1] == "c", "team member 1 tags[1]")
  println("test_array_of_structs: PASS")

  // --- Test 7: String escaping ---
  var esc: Address = {
    street: "line1\nline2",
    city: "O\"Brien"
  }
  var escYaml: str = esc.encode(Yaml.encoder())
  var esc2: Address = Address.decode(Yaml.decoder(escYaml))
  assert(esc2.street == "line1\nline2", "escape roundtrip newline")
  assert(esc2.city == "O\"Brien", "escape roundtrip quote")
  println("test_string_escaping: PASS")

  // --- Test 8: @alias decode (single struct) ---
  // Mirrors skynet EdgeRuleYaml: YAML uses "type" but field is "kind"
  var aliasYaml: str = "type: \"temporal\"\nmax_gap_ms: 30000\nthreshold: 0.85"
  var rule: EdgeRule = EdgeRule.decode(Yaml.decoder(aliasYaml))
  assert(rule.kind == "temporal", "alias decode kind")
  assert(rule.maxGapMs == 30000, "alias decode maxGapMs")
  assert(rule.threshold == 0.85, "alias decode threshold")
  println("test_alias_decode: PASS")

  // --- Test 9: Array of @alias structs in parent with @alias field ---
  // Mirrors skynet GraphEngineFileConfig with edge_rules: EdgeRuleYaml[]
  var configYaml: str = "name: \"crusher\"\nedge_rules:\n  - type: \"temporal\"\n    max_gap_ms: 30000\n    threshold: 0.0\n  - type: \"similarity\"\n    max_gap_ms: 0\n    threshold: 0.85"
  var cfg: RuleConfig = RuleConfig.decode(Yaml.decoder(configYaml))
  assert(cfg.name == "crusher", "alias array config name")
  assert(cfg.edgeRules.length == 2, "alias array length")
  assert(cfg.edgeRules[0].kind == "temporal", "alias array [0].kind")
  assert(cfg.edgeRules[0].maxGapMs == 30000, "alias array [0].maxGapMs")
  assert(cfg.edgeRules[1].kind == "similarity", "alias array [1].kind")
  assert(cfg.edgeRules[1].threshold == 0.85, "alias array [1].threshold")
  println("test_alias_array_of_structs: PASS")

  // --- Test 10: @alias roundtrip (encode then decode) ---
  var original_cfg: RuleConfig = {
    name: "roundtrip",
    edgeRules: {
      EdgeRule {
        kind: "causal",
        maxGapMs: 5000,
        threshold: 0.4
      },
      EdgeRule {
        kind: "sliding_window",
        maxGapMs: 0,
        threshold: 0.0
      }
    }
  }
  var rtCfgYaml: str = original_cfg.encode(Yaml.encoder())
  var rt_cfg: RuleConfig = RuleConfig.decode(Yaml.decoder(rtCfgYaml))
  assert(rt_cfg.name == "roundtrip", "alias roundtrip name")
  assert(rt_cfg.edgeRules.length == 2, "alias roundtrip length")
  assert(rt_cfg.edgeRules[0].kind == "causal", "alias roundtrip [0].kind")
  assert(rt_cfg.edgeRules[0].maxGapMs == 5000, "alias roundtrip [0].maxGapMs")
  assert(rt_cfg.edgeRules[1].kind == "sliding_window", "alias roundtrip [1].kind")
  println("test_alias_roundtrip: PASS")

  // --- Test 11: @alias with unquoted bare strings (real YAML config style) ---
  // Skynet configs use unquoted values like "type: temporal" not "type: \"temporal\""
  var bareYaml: str = "name: crusher\nedge_rules:\n  - type: temporal\n    max_gap_ms: 30000\n    threshold: 0.0\n  - type: similarity\n    max_gap_ms: 0\n    threshold: 0.85"
  var bareCfg: RuleConfig = RuleConfig.decode(Yaml.decoder(bareYaml))
  assert(bareCfg.name == "crusher", "bare alias config name")
  assert(bareCfg.edgeRules.length == 2, "bare alias array length")
  assert(bareCfg.edgeRules[0].kind == "temporal", "bare alias [0].kind")
  assert(bareCfg.edgeRules[0].maxGapMs == 30000, "bare alias [0].maxGapMs")
  assert(bareCfg.edgeRules[1].kind == "similarity", "bare alias [1].kind")
  assert(bareCfg.edgeRules[1].threshold == 0.85, "bare alias [1].threshold")
  println("test_alias_bare_strings: PASS")

  // --- Test 12: Comments in YAML (the skynet bug) ---
  // The graph-engine config has comments between array items.
  // The parser must skip # comment lines to parse the array correctly.
  var commentYaml: str = "name: crusher\nedge_rules:\n  # Connect sequential readings\n  - type: temporal\n    max_gap_ms: 30000\n    threshold: 0.0\n  # Cluster similar states\n  - type: similarity\n    max_gap_ms: 0\n    threshold: 0.85"
  var commentCfg: RuleConfig = RuleConfig.decode(Yaml.decoder(commentYaml))
  assert(commentCfg.name == "crusher", "comment config name")
  assert(commentCfg.edgeRules.length == 2, $"comment array length: expected 2, got {commentCfg.edgeRules.length}")
  assert(commentCfg.edgeRules[0].kind == "temporal", "comment [0].kind")
  assert(commentCfg.edgeRules[0].maxGapMs == 30000, "comment [0].maxGapMs")
  assert(commentCfg.edgeRules[1].kind == "similarity", "comment [1].kind")
  assert(commentCfg.edgeRules[1].threshold == 0.85, "comment [1].threshold")
  println("test_comments_in_yaml: PASS")

  // --- Test 13: Inline comment after value ---
  var inlineCommentYaml: str = "name: crusher  # this is the name\nage: 42  # the age"
  var icPerson: Person = Person.decode(Yaml.decoder(inlineCommentYaml))
  assert(icPerson.name == "crusher", "inline comment name")
  assert(icPerson.age == 42, "inline comment age")
  println("test_inline_comments: PASS")

  println("\nAll Yaml tests passed!")
